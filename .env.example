# ---- API (apps/api) ----
# Cadena de conexión Prisma. SQLite por defecto (cero instalación).
DATABASE_URL="file:./dev.db"
# Puerto del servidor Express
API_PORT=4000
# Secreto para firmar los JWT (cambiar en producción)
JWT_SECRET="dev-secret-change-me"
# Caducidad del token
JWT_EXPIRES_IN="7d"
# Origen permitido para CORS (el frontend de Vite)
WEB_ORIGIN="http://localhost:5173"

# ---- Web (apps/web) ----
# URL base de la API que consume el frontend
VITE_API_URL="http://localhost:4000"
